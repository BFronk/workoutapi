{
  "openapi": "3.0.0",
  "info": {
    "title": "Workout API",
    "version": "1.0.0",
    "description": "API for managing workouts with authentication"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local server"
    },
    {
      "url": "https://workoutapi-jl18.onrender.com",
      "description": "Production server"
    }
  ],
  "paths": {
    "/register": {
      "post": {
        "summary": "Register a new user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "email": "test@test.com",
                "password": "123456"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User registered successfully"
          },
          "400": {
            "description": "User already exists or invalid input"
          }
        }
      }
    },

    "/login": {
      "post": {
        "summary": "Login user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "email": "test@test.com",
                "password": "123456"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful"
          },
          "400": {
            "description": "User not found"
          },
          "401": {
            "description": "Invalid password"
          }
        }
      }
    },

    "/logout": {
      "post": {
        "summary": "Logout user",
        "responses": {
          "200": {
            "description": "Logged out successfully"
          }
        }
      }
    },

    "/workouts": {
      "get": {
        "summary": "Get all workouts (requires login)",
        "responses": {
          "200": {
            "description": "List of workouts",
            "content": {
              "application/json": {
                "example": [
                  {
                    "_id": "123",
                    "name": "Bench Press",
                    "muscleGroup": "Chest",
                    "sets": 3,
                    "reps": 10,
                    "weight": 135,
                    "date": "2026-03-28",
                    "notes": "Felt strong"
                  }
                ]
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "summary": "Create a new workout (requires login)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "name": "Squat",
                "muscleGroup": "Legs",
                "sets": 4,
                "reps": 8,
                "weight": 185,
                "date": "2026-03-28",
                "notes": "Heavy day"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Workout created"
          },
          "400": {
            "description": "Invalid input"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },

    "/workouts/{id}": {
      "get": {
        "summary": "Get a workout by ID (requires login)",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Workout found"
          },
          "400": {
            "description": "Invalid ID"
          },
          "404": {
            "description": "Workout not found"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "put": {
        "summary": "Update a workout (requires login)",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "name": "Updated Workout",
                "muscleGroup": "Back",
                "sets": 4,
                "reps": 12,
                "weight": 155,
                "date": "2026-03-28",
                "notes": "Updated notes"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Workout updated"
          },
          "400": {
            "description": "Invalid input or ID"
          },
          "404": {
            "description": "Workout not found"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "delete": {
        "summary": "Delete a workout (requires login)",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Workout deleted"
          },
          "400": {
            "description": "Invalid ID"
          },
          "404": {
            "description": "Workout not found"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  }
}